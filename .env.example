# ─── Required ─────────────────────────────────────────────────────────────────
# Gemini powers every agent (query rewrite, grading, answering, plan building).
# Get a key from https://aistudio.google.com/apikey  (GOOGLE_API_KEY also works).
GEMINI_API_KEY=AIza...

# ─── Model roles (optional) ───────────────────────────────────────────────────
# Model for answers/plans (GEN) and for the rewrite/grade steps (FAST).
# Grading quality drives the answer-vs-escalate decision, so use a capable model
# for FAST — lite models give noisy confidence. To spread across two free-tier
# quota buckets you *can* set FAST to gemini-flash-lite-latest, at some accuracy cost.
# NOTE: Gemini FREE-tier per-model daily limits are small (e.g. ~20/day for
# gemini-2.5-flash) and each chat uses 3-4 calls. Enable pay-as-you-go billing
# (cheap) for repeated use; gemini-2.5-flash is the highest-quality option.
GEN_MODEL=gemini-3-flash-preview
FAST_MODEL=gemini-3-flash-preview

# ─── Retrieval (optional) ─────────────────────────────────────────────────────
# Confidence below this routes the question to a human + logs a KB gap.
APP_CONFIDENCE_THRESHOLD=0.5

# Dense hybrid retrieval uses Google's embedding model via the same key (on by
# default). Set EMBEDDINGS_PROVIDER=none for BM25-only (skips the cold-start
# embedding call — faster first request, slightly weaker semantic recall).
EMBEDDINGS_PROVIDER=auto
EMBED_MODEL=models/gemini-embedding-001
